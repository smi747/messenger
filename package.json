{
  "name": "messenger",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "prebuild": "tsc --noEmit",
    "build": "tsc --noEmit && vite build",
    "start": "tsc --noEmit && vite build && node server.js",
    "pretty": "prettier --write \"./**/*.{js,jsx,mjs,cjs,ts,tsx,json,scss,css}\"",
    "lint": "eslint",
    "lint:fix": "eslint --fix"
  },
  "devDependencies": {
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "sass": "^1.98.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.57.2",
    "vite": "^8.0.0"
  },
  "dependencies": {
    "express": "^5.2.1",
    "handlebars": "^4.7.8"
  }
}
